# ─────────────────────────────────────────────────────
# HPC AI Learning Platform — Environment Configuration
# Copy to .env and edit as needed
# ─────────────────────────────────────────────────────

# Port the platform is served on (default 80)
PORT=80

# Secret key for JWT signing — generate with: openssl rand -hex 32
HPCAI_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Enable/disable the sandboxed code runner
HPCAI_SANDBOX_ENABLED=true

# Enable/disable the in-browser terminal
HPCAI_TERMINAL_ENABLED=true
